<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Trabajemos Juntos</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Merriweather:ital,wght@0,300;0,400;0,700;1,400&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --background: oklch(0.9735 0.0261 90.0953);
  --foreground: oklch(0.3092 0.0518 219.6516);
  --card: oklch(0.9306 0.0260 92.4020);
  --card-foreground: oklch(0.3092 0.0518 219.6516);
  --primary: oklch(0.5924 0.2025 355.8943);
  --primary-foreground: oklch(1 0 0);
  --secondary: oklch(0.6437 0.1019 187.3840);
  --muted: oklch(0.6979 0.0159 196.7940);
  --muted-foreground: oklch(0.3092 0.0518 219.6516);
  --accent: oklch(0.5808 0.1732 39.5003);
  --accent-foreground: oklch(1 0 0);
  --destructive: oklch(0.5863 0.2064 27.1172);
  --border: oklch(0.6537 0.0197 205.2618);
  --input: oklch(0.6537 0.0197 205.2618);
  --ring: oklch(0.5924 0.2025 355.8943);
  --font-sans: Poppins, ui-sans-serif, sans-serif, system-ui;
  --font-serif: Merriweather, ui-serif, serif;
  --font-mono: "Roboto Mono", ui-monospace, monospace;
  --radius: 0.25rem;
  --shadow-sm: 2px 2px 4px 0px hsl(196 83% 10% / 0.15), 2px 1px 2px -1px hsl(196 83% 10% / 0.15);
  --shadow-lg: 2px 2px 4px 0px hsl(196 83% 10% / 0.15), 2px 4px 6px -1px hsl(196 83% 10% / 0.15);
  --shadow-xl: 2px 2px 4px 0px hsl(196 83% 10% / 0.15), 2px 8px 10px -1px hsl(196 83% 10% / 0.15);
}
html[data-theme="dark"]{
  --background: oklch(0.2673 0.0486 219.8169);
  --foreground: oklch(0.6979 0.0159 196.7940);
  --card: oklch(0.3092 0.0518 219.6516);
  --card-foreground: oklch(0.6979 0.0159 196.7940);
  --muted: oklch(0.5230 0.0283 219.1365);
  --muted-foreground: oklch(0.6979 0.0159 196.7940);
  --border: oklch(0.5230 0.0283 219.1365);
  --input: oklch(0.5230 0.0283 219.1365);
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:var(--font-sans);
  background:var(--background);
  color:var(--foreground);
  min-height:100vh;
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
  position:relative;
}
/* Atmósfera tech: mesh + grilla fina */
body::before{
  content:"";position:fixed;inset:0;z-index:0;pointer-events:none;
  background:
    radial-gradient(60% 50% at 12% 8%, oklch(0.5924 0.2025 355.8943 / 0.18), transparent 70%),
    radial-gradient(55% 45% at 92% 18%, oklch(0.6437 0.1019 187.3840 / 0.16), transparent 70%),
    radial-gradient(60% 60% at 80% 95%, oklch(0.5808 0.1732 39.5003 / 0.12), transparent 70%);
  filter:blur(8px);
}
body::after{
  content:"";position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.4;
  background-image:
    linear-gradient(to right, oklch(0.3092 0.0518 219.6516 / 0.04) 1px, transparent 1px),
    linear-gradient(to bottom, oklch(0.3092 0.0518 219.6516 / 0.04) 1px, transparent 1px);
  background-size:46px 46px;
  -webkit-mask-image:radial-gradient(80% 80% at 50% 40%, #000, transparent);
          mask-image:radial-gradient(80% 80% at 50% 40%, #000, transparent);
}

.shell{
  position:relative;z-index:1;
  min-height:100vh;
  display:grid;
  grid-template-columns:340px 1fr;
}

/* ---------- RAIL ---------- */
.rail{
  position:sticky;top:0;height:100vh;
  padding:40px 34px;
  display:flex;flex-direction:column;
  border-right:1px solid var(--border);
  background:linear-gradient(180deg, oklch(0.9306 0.0260 92.4020 / 0.5), transparent);
  backdrop-filter:blur(6px);
}
html[data-theme="dark"] .rail{background:linear-gradient(180deg, oklch(0.3092 0.0518 219.6516 / 0.4), transparent)}
.brand{display:flex;align-items:center;gap:12px;margin-bottom:auto}
.brand .mark{
  width:40px;height:40px;border-radius:var(--radius);
  background:linear-gradient(135deg, var(--primary), var(--accent));
  display:grid;place-items:center;color:#fff;font-weight:700;font-size:18px;
  box-shadow:var(--shadow-sm);
}
.brand .name{font-weight:600;font-size:15px;letter-spacing:.01em}
.brand .name small{display:block;font-family:var(--font-mono);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted-foreground);margin-top:2px}

.steps{display:flex;flex-direction:column;gap:2px;margin:48px 0}
.step-item{
  display:flex;align-items:center;gap:14px;padding:11px 12px;border-radius:var(--radius);
  font-size:13.5px;color:var(--muted-foreground);transition:.35s cubic-bezier(.4,0,.2,1);
  border:1px solid transparent;
}
.step-item .idx{
  font-family:var(--font-mono);font-size:11px;width:26px;height:26px;flex:0 0 26px;
  display:grid;place-items:center;border:1px solid var(--border);border-radius:50%;
  transition:.35s;
}
.step-item.active{color:var(--foreground);background:oklch(0.5924 0.2025 355.8943 / 0.08);border-color:oklch(0.5924 0.2025 355.8943 / 0.25)}
.step-item.active .idx{border-color:var(--primary);color:var(--primary)}
.step-item.done{color:var(--foreground)}
.step-item.done .idx{background:var(--secondary);border-color:var(--secondary);color:#fff}

.exclusive{
  border:1px solid var(--border);border-radius:var(--radius);padding:18px;
  background:oklch(0.5808 0.1732 39.5003 / 0.08);
}
.exclusive .tag{font-family:var(--font-mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);display:flex;align-items:center;gap:7px}
.exclusive .tag::before{content:"";width:7px;height:7px;border-radius:50%;background:var(--accent);box-shadow:0 0 0 4px oklch(0.5808 0.1732 39.5003 / 0.2);animation:pulse 2s infinite}
@keyframes pulse{50%{box-shadow:0 0 0 7px oklch(0.5808 0.1732 39.5003 / 0)}}
.exclusive p{font-size:13px;margin-top:9px;line-height:1.5}
.exclusive b{font-family:var(--font-serif);font-style:italic}

/* ---------- STAGE ---------- */
.stage{padding:56px 8vw;display:flex;align-items:center;justify-content:center}
.panel{width:100%;max-width:600px}

.progress-top{display:none}

.card{
  background:oklch(0.9306 0.0260 92.4020 / 0.72);
  border:1px solid var(--border);
  border-radius:calc(var(--radius) + 2px);
  box-shadow:var(--shadow-xl);
  backdrop-filter:blur(14px);
  padding:48px 46px;
}
html[data-theme="dark"] .card{background:oklch(0.3092 0.0518 219.6516 / 0.7)}

.eyebrow{font-family:var(--font-mono);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--primary);margin-bottom:18px;display:flex;gap:10px;align-items:center}
.eyebrow span{flex:1;height:1px;background:var(--border)}
h1{font-family:var(--font-serif);font-weight:700;font-size:42px;line-height:1.08;letter-spacing:-.01em;margin-bottom:20px}
h2{font-family:var(--font-serif);font-weight:700;font-size:27px;line-height:1.15;margin-bottom:10px}
.lead{font-size:15.5px;line-height:1.65;color:var(--muted-foreground);margin-bottom:14px}
.sub{font-size:14px;color:var(--muted-foreground);margin-bottom:28px}

.field{margin-bottom:22px}
.field label{display:block;font-size:13px;font-weight:500;margin-bottom:8px}
.field .req{color:var(--accent)}
input,textarea{
  width:100%;font-family:var(--font-sans);font-size:15px;color:var(--foreground);
  background:var(--background);border:1px solid var(--input);border-radius:var(--radius);
  padding:13px 15px;transition:.2s;
}
textarea{resize:vertical;min-height:96px;line-height:1.55}
input:focus,textarea:focus{outline:none;border-color:var(--ring);box-shadow:0 0 0 3px oklch(0.5924 0.2025 355.8943 / 0.18)}
input::placeholder,textarea::placeholder{color:var(--muted-foreground);opacity:.6}
.err input,.err textarea{border-color:var(--destructive)}
.err-msg{display:none;font-size:12px;color:var(--destructive);margin-top:6px}
.err .err-msg{display:block}

.options{display:flex;flex-direction:column;gap:11px;margin-bottom:8px}
.opt{
  display:flex;align-items:center;gap:14px;padding:15px 17px;cursor:pointer;
  border:1px solid var(--border);border-radius:var(--radius);background:var(--background);
  transition:.2s;font-size:15px;
}
.opt:hover{border-color:var(--primary)}
.opt .key{font-family:var(--font-mono);font-size:12px;width:28px;height:28px;flex:0 0 28px;display:grid;place-items:center;border:1px solid var(--border);border-radius:var(--radius);transition:.2s}
.opt input{display:none}
.opt.sel{border-color:var(--primary);background:oklch(0.5924 0.2025 355.8943 / 0.07)}
.opt.sel .key{background:var(--primary);border-color:var(--primary);color:#fff}

.nav{display:flex;align-items:center;justify-content:space-between;margin-top:34px;gap:14px}
.btn{
  font-family:var(--font-sans);font-size:14.5px;font-weight:500;cursor:pointer;
  padding:13px 26px;border-radius:var(--radius);border:1px solid transparent;transition:.2s;
  display:inline-flex;align-items:center;gap:9px;
}
.btn-primary{background:var(--primary);color:var(--primary-foreground);box-shadow:var(--shadow-sm)}
.btn-primary:hover{transform:translateY(-1px);box-shadow:var(--shadow-lg)}
.btn-ghost{background:transparent;color:var(--muted-foreground);border-color:var(--border)}
.btn-ghost:hover{color:var(--foreground);border-color:var(--foreground)}
.btn-ghost.hidden{visibility:hidden}
.btn .ar{transition:.2s}
.btn-primary:hover .ar{transform:translateX(3px)}

.meter{font-family:var(--font-mono);font-size:11px;letter-spacing:.14em;color:var(--muted-foreground)}

/* transición de pasos */
.screen{display:none;animation:enter .45s cubic-bezier(.16,1,.3,1)}
.screen.show{display:block}
@keyframes enter{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}

/* éxito */
.done-state{text-align:center;padding:14px 0}
.done-state .ring{
  width:72px;height:72px;border-radius:50%;margin:0 auto 24px;display:grid;place-items:center;
  background:var(--secondary);color:#fff;font-size:34px;box-shadow:var(--shadow-lg);
}

/* toggle tema */
.theme-tog{position:fixed;top:22px;right:24px;z-index:5;width:40px;height:40px;border-radius:50%;border:1px solid var(--border);background:var(--card);color:var(--foreground);cursor:pointer;font-size:16px;display:grid;place-items:center;backdrop-filter:blur(8px)}

@media (max-width:920px){
  .shell{grid-template-columns:1fr}
  .rail{display:none}
  .stage{padding:74px 22px 40px}
  .card{padding:34px 24px}
  h1{font-size:33px}
  .progress-top{display:block;margin-bottom:22px}
  .progress-top .track{height:4px;background:var(--border);border-radius:99px;overflow:hidden}
  .progress-top .fill{height:100%;background:var(--primary);transition:.4s;border-radius:99px}
  .progress-top .lbl{font-family:var(--font-mono);font-size:10px;letter-spacing:.14em;color:var(--muted-foreground);margin-top:8px;text-transform:uppercase}
}
@media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
<body>
<button class="theme-tog" id="theme" aria-label="Cambiar tema">◐</button>

<div class="shell">
  <aside class="rail">
    <div class="brand">
      <div class="mark">E</div>
      <div class="name">Estudio<small>Brand Systems</small></div>
    </div>

    <nav class="steps" id="rail-steps"></nav>

    <div class="exclusive">
      <div class="tag">Cupos limitados</div>
      <p>Solo aceptamos <b>3 proyectos</b> nuevos al mes para garantizar foco y calidad.</p>
    </div>
  </aside>

  <main class="stage">
    <div class="panel">
      <div class="progress-top">
        <div class="track"><div class="fill" id="topfill"></div></div>
        <div class="lbl" id="toplbl"></div>
      </div>

      <div class="card">
        <!-- 1 -->
        <section class="screen show" data-step="0">
          <div class="eyebrow">Aplicación · 2 min <span></span></div>
          <h1>Trabajemos juntos.</h1>
          <p class="lead">No creemos en soluciones genéricas. Diseñamos sistemas visuales y estratégicos a la medida para que tu negocio se posicione como una marca atractiva y deje de competir por precio.</p>
          <p class="sub">Este formulario nos ayuda a saber si somos el equipo ideal para ti. Empecemos.</p>
          <div class="nav">
            <button class="btn btn-ghost hidden">Atrás</button>
            <button class="btn btn-primary" data-next>Comenzar <span class="ar">→</span></button>
          </div>
        </section>

        <!-- 2 -->
        <section class="screen" data-step="1">
          <div class="eyebrow">Sobre ti <span></span></div>
          <h2>¿Con quién hablamos?</h2>
          <p class="sub">Tus datos para coordinar la conversación.</p>
          <div class="field" data-validate>
            <label>Nombre completo <span class="req">*</span></label>
            <input type="text" name="nombre" placeholder="Tu nombre">
            <div class="err-msg">Cuéntanos tu nombre.</div>
          </div>
          <div class="field" data-validate data-type="email">
            <label>Correo <span class="req">*</span></label>
            <input type="email" name="email" placeholder="hola@tumarca.com">
            <div class="err-msg">Ingresa un correo válido.</div>
          </div>
          <div class="field" data-validate>
            <label>WhatsApp <span class="req">*</span></label>
            <input type="text" name="whatsapp" placeholder="+51 999 999 999">
            <div class="err-msg">Necesitamos un número de contacto.</div>
          </div>
          <div class="nav">
            <button class="btn btn-ghost" data-prev>← Atrás</button>
            <button class="btn btn-primary" data-next>Continuar <span class="ar">→</span></button>
          </div>
        </section>

        <!-- 3 -->
        <section class="screen" data-step="2">
          <div class="eyebrow">Servicio <span></span></div>
          <h2>¿Qué tipo de servicio buscas?</h2>
          <p class="sub">Elige la opción que más se acerca.</p>
          <div class="options" data-radio data-validate>
            <label class="opt"><span class="key">A</span><input type="radio" name="servicio" value="Rebranding completo">Rebranding completo (empresa activa)</label>
            <label class="opt"><span class="key">B</span><input type="radio" name="servicio" value="Nueva identidad">Nueva identidad de marca (nueva empresa)</label>
            <label class="opt"><span class="key">C</span><input type="radio" name="servicio" value="Packaging">Packaging</label>
            <label class="opt"><span class="key">D</span><input type="radio" name="servicio" value="Otro">Otro</label>
          </div>
          <div class="err-msg" style="margin-top:10px">Selecciona una opción.</div>
          <div class="nav">
            <button class="btn btn-ghost" data-prev>← Atrás</button>
            <button class="btn btn-primary" data-next>Continuar <span class="ar">→</span></button>
          </div>
        </section>

        <!-- 4 -->
        <section class="screen" data-step="3">
          <div class="eyebrow">Encaje <span></span></div>
          <h2>¿Por qué trabajar juntos es buena idea?</h2>
          <p class="sub">Lo que esperas lograr o por qué te interesa el estudio.</p>
          <div class="field" data-validate>
            <textarea name="motivo" placeholder="Escribe aquí..."></textarea>
            <div class="err-msg">Cuéntanos un poco más.</div>
          </div>
          <div class="nav">
            <button class="btn btn-ghost" data-prev>← Atrás</button>
            <button class="btn btn-primary" data-next>Continuar <span class="ar">→</span></button>
          </div>
        </section>

        <!-- 5 -->
        <section class="screen" data-step="4">
          <div class="eyebrow">Tu empresa <span></span></div>
          <h2>Descríbela en una o dos oraciones.</h2>
          <p class="sub">Qué hace y a quién sirve.</p>
          <div class="field" data-validate>
            <textarea name="empresa" placeholder="Somos una marca que..."></textarea>
            <div class="err-msg">Falta describir tu empresa.</div>
          </div>
          <div class="nav">
            <button class="btn btn-ghost" data-prev>← Atrás</button>
            <button class="btn btn-primary" data-next>Continuar <span class="ar">→</span></button>
          </div>
        </section>

        <!-- 6 -->
        <section class="screen" data-step="5">
          <div class="eyebrow">Plazos <span></span></div>
          <h2>¿Cuál es el plazo ideal?</h2>
          <p class="sub">Cuándo te gustaría tener esto resuelto.</p>
          <div class="field" data-validate>
            <input type="text" name="plazo" placeholder="Ej: en 6 semanas / antes de fin de año">
            <div class="err-msg">Indícanos un plazo aproximado.</div>
          </div>
          <div class="nav">
            <button class="btn btn-ghost" data-prev>← Atrás</button>
            <button class="btn btn-primary" data-submit>Enviar aplicación <span class="ar">→</span></button>
          </div>
        </section>

        <!-- éxito -->
        <section class="screen" data-step="6">
          <div class="done-state">
            <div class="ring">✓</div>
            <h2>Aplicación recibida.</h2>
            <p class="lead" style="margin:0 auto;max-width:380px">Revisaremos tu información y, si hay encaje, te escribiremos pronto. Gracias por tu interés.</p>
          </div>
        </section>
      </div>
    </div>
  </main>
</div>

<script>
const screens=[...document.querySelectorAll('.screen')];
const TOTAL=6; // pasos de contenido (sin contar éxito)
let cur=0;

const railSteps=['Inicio','Sobre ti','Servicio','Encaje','Tu empresa','Plazos'];
const railEl=document.getElementById('rail-steps');
railSteps.forEach((t,i)=>{
  const d=document.createElement('div');
  d.className='step-item';
  d.innerHTML=`<span class="idx">${String(i+1).padStart(2,'0')}</span>${t}`;
  railEl.appendChild(d);
});
const railItems=[...railEl.children];

function render(){
  screens.forEach((s,i)=>s.classList.toggle('show',i===cur));
  railItems.forEach((it,i)=>{
    it.classList.toggle('active',i===cur);
    it.classList.toggle('done',i<cur);
  });
  const shown=Math.min(cur,TOTAL-1);
  document.getElementById('topfill').style.width=((cur)/(TOTAL-1)*100)+'%';
  document.getElementById('toplbl').textContent=`Paso ${Math.min(cur+1,TOTAL)} de ${TOTAL}`;
  document.querySelector('.stage').scrollTo?.(0,0);
}

function clearErr(el){el.classList.remove('err')}

function validate(stepEl){
  let ok=true;
  stepEl.querySelectorAll('[data-validate]').forEach(f=>{
    f.classList.remove('err');
    if(f.dataset.radio!==undefined){
      if(!f.querySelector('input:checked')){f.parentElement.querySelector('.err-msg').style.display='block';ok=false;}
      else f.parentElement.querySelector('.err-msg').style.display='none';
      return;
    }
    const inp=f.querySelector('input,textarea');
    const v=(inp.value||'').trim();
    if(!v){f.classList.add('err');ok=false;return;}
    if(f.dataset.type==='email' && !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(v)){f.classList.add('err');ok=false;}
  });
  return ok;
}

document.querySelectorAll('[data-next]').forEach(b=>b.addEventListener('click',()=>{
  if(!validate(screens[cur]))return;
  cur++;render();
}));
document.querySelectorAll('[data-prev]').forEach(b=>b.addEventListener('click',()=>{cur--;render();}));
document.querySelector('[data-submit]').addEventListener('click',()=>{
  if(!validate(screens[cur]))return;
  cur=TOTAL; render();
});

// radios
document.querySelectorAll('[data-radio]').forEach(g=>{
  g.querySelectorAll('.opt').forEach(o=>o.addEventListener('click',()=>{
    g.querySelectorAll('.opt').forEach(x=>x.classList.remove('sel'));
    o.classList.add('sel');
    g.parentElement.querySelector('.err-msg').style.display='none';
  }));
});

// limpiar error al escribir
document.querySelectorAll('input,textarea').forEach(i=>i.addEventListener('input',e=>{
  const f=e.target.closest('[data-validate]'); if(f)clearErr(f);
}));

// tema
const themeBtn=document.getElementById('theme');
themeBtn.addEventListener('click',()=>{
  const h=document.documentElement;
  h.dataset.theme=h.dataset.theme==='dark'?'light':'dark';
});

render();
</script>
</body>
</html>
